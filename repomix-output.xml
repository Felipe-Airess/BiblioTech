        foreach ($livros as $info) {
            $autor = Autor::firstOrCreate(['nome' => $info['autor']]);
            Livros::factory()->create([
                'titulo' => $info['titulo'],
                'autor_id' => $autor->id,
                'categoria' => 'Romance',
            ]);
        }
    }
}
